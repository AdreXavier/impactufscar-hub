# Required environment variables for Impact Hub UFSCar backend
# Copy this file to backend/.env and fill in the values.

PORT=3000

# REQUIRED: change to a long, random string in production
JWT_SECRET=change-this-to-a-long-random-secret

JWT_EXPIRES_IN=8h

# Admin user created by "npm run seed" (run once after setup)
ADMIN_EMAIL=admin@impactufscar.com
ADMIN_PASSWORD=impact2026!

# Path to SQLite database file (relative to backend/)
DB_PATH=./data/hub.db

# CORS: set to your domain in production to restrict cross-origin access.
# Leave empty (or unset) to disable CORS headers (same-origin only in browsers).
# Set to "*" only for development with separate frontend dev server.
# Example for production: CORS_ORIGIN=https://yourproductiondomain.com
# CORS_ORIGIN=
